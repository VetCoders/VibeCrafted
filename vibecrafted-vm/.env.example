# vc-workspace — env template. Copy to .env and fill in.
#   cp .env.example .env  &&  $EDITOR .env
# .env is gitignored — never commit secrets.

# ── Tailnet ─────────────────────────────────────────────────────────────────
# Auth key from https://login.tailscale.com/admin/settings/keys
# Use an ephemeral key (tskey-auth-..._ephemeral) for short-lived dev boxes.
TAILSCALE_AUTHKEY=
# Node name on the tailnet (peers will: ssh root@<this>)
TAILSCALE_HOSTNAME=vc-workspace-dragon
# ACL tag — LEAVE BLANK unless you define the tag in your tailnet ACL AND add an
# ssh rule that matches tagged nodes. tag:devbox is NOT in the vetcoders ACL, and
# tagging would bypass the autogroup:self ssh rule. Blank = user-owned node.
TAILSCALE_TAGS=

# ── Workspace mount ─────────────────────────────────────────────────────────
# Host path to the MULTIROOT repo tree, mounted at /workspace.
# dragon:        ~/Libraxis/vc-runtime   (default if left blank)
# LibraxisShare: /Volumes/LibraxisShare/vc-runtime
VC_RUNTIME_DIR=

# ── GPG signing (optional) ──────────────────────────────────────────────────
LOCTREE_GPG_KEY_ID=

# ── Misc ────────────────────────────────────────────────────────────────────
AICX_NO_MUTATION_WARN=0
TERM=xterm-256color
COLORTERM=truecolor

# 𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. with AI Agents by VetCoders (c)2024-2026 LibraxisAI
