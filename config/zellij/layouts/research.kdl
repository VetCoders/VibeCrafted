// research — triple-agent research workspace
// Launch: vibecrafted dashboard research
//
// Design: synthesis-focused. The synthesis pane gets prime real estate (left,
// focused). Three agent panes are stacked vertically on the right — compact
// but visible. When agents complete, results flow to synthesis.
//
// Swap layouts:
//   "default"   — synthesis left + 3 agents stacked right
//   "grid"      — 2x2 equal grid (all agents equal weight)
//   "synthesis"  — full screen synthesis (agents in tabs)
//
// VibeCrafted with AI Agents (c)2026 VetCoders
layout {
    // new_tab_template removed: Zellij 0.44 broke `children` inside it.
    // default_tab_template covers both existing and new tabs.
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
        // Plan 12 — agent-native status row: AICX session counter + loctree drift.
        // Two thin panes laid horizontally so the operator sees both signals
        // at a glance without dominating the workspace.
        pane size=1 split_direction="vertical" {
            pane name="aicx-status" size="50%" borderless=true command="bash" start_suspended=false {
                args "-lc" "for root in \"${VIBECRAFTED_HOME:-$HOME/.vibecrafted}/tools/vibecrafted-current/config/zellij\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/config/zellij}\" \"./config/zellij\"; do if [[ -n \"$root\" && -x \"$root/aicx-status.sh\" ]]; then exec \"$root/aicx-status.sh\"; fi; done; printf 'aicx: status helper not found\\n'; sleep 86400"
            }
            pane name="loctree-drift" size="50%" borderless=true command="bash" start_suspended=false {
                args "-lc" "for root in \"${VIBECRAFTED_HOME:-$HOME/.vibecrafted}/tools/vibecrafted-current/config/zellij\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/config/zellij}\" \"./config/zellij\"; do if [[ -n \"$root\" && -x \"$root/loctree-drift.sh\" ]]; then exec \"$root/loctree-drift.sh\"; fi; done; printf 'loctree: drift helper not found\\n'; sleep 86400"
            }
        }
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. Research" {
        pane split_direction="vertical" {
            // Synthesis — main workspace
            pane name="synthesis" size="55%" focus=true command="zsh"
            // Agent stack — compact, right side
            pane split_direction="horizontal" size="45%" {
                pane name="claude" command="zsh"
                pane name="codex" command="zsh"
                pane name="gemini" command="zsh"
            }
        }
    }

    // Swap: 2x2 grid — all agents equal
    swap_tiled_layout name="grid" {
        tab {
            pane split_direction="horizontal" {
                pane split_direction="vertical" size="50%" {
                    pane name="claude" command="zsh"
                    pane name="codex" command="zsh"
                }
                pane split_direction="vertical" size="50%" {
                    pane name="gemini" command="zsh"
                    pane name="synthesis" focus=true command="zsh"
                }
            }
        }
    }

    // Swap: synthesis full screen
    swap_tiled_layout name="synthesis" {
        tab {
            pane name="synthesis" focus=true
        }
    }
}
