// operator — operator entrypoint
// Launch: vibecrafted start | vc-start | vibecrafted dashboard operator
//
// Design: operator gets a clean, full-screen workspace. Agents spawned via
// marbles/workflow/research open as ADDITIONAL TABS in this session — visible
// in the tab bar for at-a-glance monitoring, but never stealing focus from
// the operator's active pane.
//
// Swap layouts let the operator toggle between full-screen work and a
// split view with a monitoring sidebar — Ctrl+Shift+[ / Ctrl+Shift+].
//
// VibeCrafted with AI Agents (c)2026 VetCoders
layout {
    // Template for dynamically spawned agent tabs — every new-tab gets this
    // branded chrome automatically. Agents land here, not in operator's pane.
    // new_tab_template removed: Zellij 0.44 broke `children` inside it.
    // default_tab_template covers both existing and new tabs.
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
        // Plan 12 — agent-native status row: AICX session counter + loctree drift.
        pane size=1 split_direction="vertical" {
            pane name="aicx-status" size="50%" borderless=true command="bash" {
                args "-lc" "for root in \"${VIBECRAFTED_HOME:-$HOME/.vibecrafted}/tools/vibecrafted-current/config/zellij\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/config/zellij}\" \"./config/zellij\"; do if [[ -n \"$root\" && -x \"$root/aicx-status.sh\" ]]; then exec \"$root/aicx-status.sh\"; fi; done; printf 'aicx: status helper not found\\n'; sleep 86400"
            }
            pane name="loctree-drift" size="50%" borderless=true command="bash" {
                args "-lc" "for root in \"${VIBECRAFTED_HOME:-$HOME/.vibecrafted}/tools/vibecrafted-current/config/zellij\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/config/zellij}\" \"./config/zellij\"; do if [[ -n \"$root\" && -x \"$root/loctree-drift.sh\" ]]; then exec \"$root/loctree-drift.sh\"; fi; done; printf 'loctree: drift helper not found\\n'; sleep 86400"
            }
        }
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    // Primary operator tab — full screen, focused.
    tab name="𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. Operator" focus=true {
        pane name="operator" focus=true command="bash" {
            args "-lc" "for root in \"${VIBECRAFTED_HOME:-$HOME/.vibecrafted}/skills/vc-agents\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/.vibecrafted/skills/vc-agents}\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/skills/vc-agents}\" \"./skills/vc-agents\"; do if [[ -n \"$root\" && -x \"$root/scripts/mission-control/operator-console.sh\" ]]; then exec \"$root/scripts/mission-control/operator-console.sh\"; fi; done; export VIBECRAFTED_OPERATOR_MODE=1; printf '\\033[1;33m𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍.\\033[0m Operator Mode\\n\\n'; printf '  vibecrafted marbles codex --count 3 --depth 3\\n'; printf '  vibecrafted workflow claude -p \"Plan and implement\"\\n'; printf '  vibecrafted review codex -f /path/to/plan.md\\n\\n'; printf 'Agent tabs spawn in this session — check tab bar for status.\\n'; printf 'Swap layout: Ctrl+Shift+[ / ]\\n\\n'; exec /bin/zsh -l"
        }
    }

    // Swap layout: operator + monitoring sidebar (toggle with Ctrl+Shift+])
    swap_tiled_layout name="monitoring" {
        tab {
            pane split_direction="vertical" {
                pane name="operator" size="70%" focus=true
                pane split_direction="horizontal" size="30%" {
                    pane name="agents" command="bash" {
                        args "-lc" "for root in \"${VIBECRAFTED_HOME:-$HOME/.vibecrafted}/skills/vc-agents\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/.vibecrafted/skills/vc-agents}\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/skills/vc-agents}\" \"./skills/vc-agents\"; do if [[ -n \"$root\" && -x \"$root/scripts/mission-control/active-agents.sh\" ]]; then exec \"$root/scripts/mission-control/active-agents.sh\"; fi; done; printf 'Agent monitor not found.\\n'; exec /bin/zsh -l"
                    }
                    pane name="convergence" command="bash" {
                        args "-lc" "for root in \"${VIBECRAFTED_HOME:-$HOME/.vibecrafted}/skills/vc-agents\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/.vibecrafted/skills/vc-agents}\" \"${VIBECRAFTED_ROOT:+$VIBECRAFTED_ROOT/skills/vc-agents}\" \"./skills/vc-agents\"; do if [[ -n \"$root\" && -x \"$root/scripts/mission-control/convergence-trend.sh\" ]]; then exec \"$root/scripts/mission-control/convergence-trend.sh\"; fi; done; printf 'Convergence monitor not found.\\n'; exec /bin/zsh -l"
                    }
                }
            }
        }
    }
}
