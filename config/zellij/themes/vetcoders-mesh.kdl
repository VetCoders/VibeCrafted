// VetCoders mesh-aware zellij themes
// Plan 12 (META_22) — Wave 4 agent-native runtime cut.
//
// Kronika 2026-05-05 — VetCoders mesh topology. Each workstation gets a
// canonical accent so the operator instantly knows which machine they are
// looking at when peering through screen-share, mirrored displays, or a
// browser-shared tmux/zellij session.
//
//   dragon   — red    — LibraxisAI server, central hub
//   sztudio  — purple — Monika's desktop
//   silver   — cyan   — Monika's laptop
//   div0     — green  — Maciej's laptop, primary dev
//
// The base palette is the canonical "vibecrafted" theme (config.kdl). Each
// mesh variant overrides ONLY the accent (yellow + magenta + cyan are
// re-mapped) so layout chrome stays stable and only the identity color
// shifts. The neutral fallback continues to live in config.kdl.
//
// Loaded automatically by config.kdl. Selection is driven by the
// auto-theme.sh helper or the VIBECRAFTED_THEME environment override.
//
// Vibecrafted with AI Agents (c)2024-2026 LibraxisAI
themes {
    // ── vetcoders-dragon — red — LibraxisAI server, central hub ──────────
    vetcoders-dragon {
        fg 220 215 186
        bg 30 24 24
        black 20 20 24
        white 235 230 210
        red 204 36 29           // base alerts
        green 142 192 124
        yellow 224 92 80        // accent: dragon scarlet
        blue 69 133 136
        magenta 204 36 60       // identity glow
        orange 214 93 14
        cyan 224 92 80          // mirror accent
    }

    // ── vetcoders-sztudio — purple — Monika's desktop ────────────────────
    vetcoders-sztudio {
        fg 220 215 186
        bg 28 24 36
        black 20 20 24
        white 235 230 210
        red 204 36 29
        green 142 192 124
        yellow 175 122 197      // accent: sztudio violet
        blue 69 133 136
        magenta 175 122 197     // identity glow
        orange 214 93 14
        cyan 175 122 197        // mirror accent
    }

    // ── vetcoders-silver — cyan — Monika's laptop ────────────────────────
    vetcoders-silver {
        fg 220 215 186
        bg 24 30 34
        black 20 20 24
        white 235 230 210
        red 204 36 29
        green 142 192 124
        yellow 104 192 192      // accent: silver cyan
        blue 69 133 136
        magenta 104 192 192     // identity glow
        orange 214 93 14
        cyan 104 192 192        // mirror accent
    }

    // ── vetcoders-div0 — green — Maciej's laptop, primary dev ────────────
    vetcoders-div0 {
        fg 220 215 186
        bg 24 32 28
        black 20 20 24
        white 235 230 210
        red 204 36 29
        green 142 192 124
        yellow 142 192 124      // accent: div0 sage
        blue 69 133 136
        magenta 142 192 124     // identity glow
        orange 214 93 14
        cyan 142 192 124        // mirror accent
    }
}
