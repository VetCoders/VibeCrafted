# 𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. runtime stack — environment file
#
# Copy to `.env` next to docker-compose.yml and fill in:
#   cp tailscale.env.example .env
#   $EDITOR .env
#
# .env is gitignored at repo root (see .gitignore '/.env' pattern); never commit
# real auth keys.

# REQUIRED — Tailscale auth key (https://login.tailscale.com/admin/settings/keys)
# Recommended: reusable + ephemeral + tag-restricted (e.g. tag:runtime).
# Example: tskey-auth-XXXX-YYYYYYYY
TS_AUTHKEY=

# Hostname advertised to the tailnet. Becomes the magic-DNS name.
# Example: runtime-dragon → reachable as `runtime-dragon` from any tailnet device.
TS_HOSTNAME=runtime-dragon

# Extra args passed to `tailscale up`. Defaults to enabling Tailscale SSH.
# Add `--advertise-tags=tag:runtime` if your tailnet ACL needs it.
# Add `--advertise-routes=...` to expose subnets (rarely needed for runtime container).
TS_EXTRA_ARGS=--ssh

# OPTIONAL — image override (defaults to local builds).
# Set when pulling from a private registry.
# VIBECRAFTED_BASE_IMAGE=ghcr.io/vetcoders/vibecrafted-base:2.0.1
# VIBECRAFTED_RUNTIME_IMAGE=ghcr.io/vetcoders/vibecrafted-runtime:2.0.1

# OPTIONAL — host workspace bind-mount path (made available at /workspace/host
# inside the container). Useful when the runtime should see live host files.
# VIBECRAFTED_HOST_WORKSPACE=/Users/maciejgad/vc-workspace

# OPTIONAL — override the in-container sshd port. Default 22 is fine on the
# tailnet because the sidecar isolates the port from the host network.
# SSH_PORT=22
